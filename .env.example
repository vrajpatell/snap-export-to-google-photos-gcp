ENV=dev
HOST=0.0.0.0
PORT=8080
APP_BASE_URL=http://localhost:8080
USE_GCP_BACKENDS=false

GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_STAGING_BUCKET=your-staging-bucket
FIRESTORE_DATABASE=(default)
FIRESTORE_COLLECTION_JOBS=import_jobs
FIRESTORE_COLLECTION_DEDUPE=dedupe_registry

CLOUD_TASKS_QUEUE=snap-import-queue
CLOUD_TASKS_WORKER_URL=http://localhost:8080/tasks/process
CLOUD_TASKS_WORKER_AUDIENCE=http://localhost:8080
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=cloud-run-runtime@your-gcp-project-id.iam.gserviceaccount.com
CLOUD_TASKS_TASK_TOKEN=replace-with-random-shared-token

GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/google/callback
PHOTOS_OAUTH_SCOPES=https://www.googleapis.com/auth/photoslibrary.appendonly,openid,email
OAUTH_TOKEN_SECRET_ID=google-oauth-refresh-token
