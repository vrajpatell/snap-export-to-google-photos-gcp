project_id            = "your-gcp-project"
region                = "us-central1"
artifact_registry_repo = "snap-import"
api_service_name      = "snap-import-api"
worker_service_name   = "snap-import-worker"
bucket_name           = "your-project-snap-staging"
queue_name            = "snap-import-queue"
firestore_database_id = "(default)"
container_image       = "us-central1-docker.pkg.dev/your-gcp-project/snap-import/app:latest"
